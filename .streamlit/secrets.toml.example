# Streamlit secrets template for the optional Descope (OIDC) sign-in gate.
#
# Copy the [auth] section into the deployed app's secrets on Streamlit
# Community Cloud (App → ⋮ → Settings → Secrets) — do NOT commit real values.
# For local testing, copy this file to .streamlit/secrets.toml (gitignored) and
# use the localhost redirect_uri.
#
# Leave secrets unset to run the app open (no login required).

[auth]
# The deployed app's URL + /oauth2callback. For local dev:
#   http://localhost:8501/oauth2callback
redirect_uri = "https://YOUR-APP.streamlit.app/oauth2callback"
# A long random string. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
cookie_secret = "REPLACE_WITH_A_LONG_RANDOM_STRING"

[auth.descope]
# Descope Project ID (Console → Project Settings).
client_id = "YOUR_DESCOPE_PROJECT_ID"
# A Descope Access Key used as the OIDC client secret (Console → Access Keys).
client_secret = "YOUR_DESCOPE_ACCESS_KEY"
# Descope's OIDC discovery document for your project.
server_metadata_url = "https://api.descope.com/YOUR_DESCOPE_PROJECT_ID/.well-known/openid-configuration"

# Optional: restrict access to specific signed-in emails. Omit this whole
# section to allow anyone who can authenticate through your Descope flow.
# Running roster of collected emails — paste this [access] block (uncommented)
# into the deployed app's secrets. Append friends' emails as they come in.
[access]
allowed_emails = [
    "jimmymick@gmail.com",
    # Mike — pending
    # Tunk — pending
    # Clayton — pending
    "eman1885@gmail.com",  # Eman
]
