# Run logs (scratch output)
*.log

# Auto-generated weekly outputs from the scheduled preview/grade jobs
predictions/auto-*.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# uv / virtualenv
.venv/

# nflreadpy data cache
.cache/
*.parquet

# Secrets / local env
.env

# Streamlit secrets (Descope client secret etc.) — configure in the Community
# Cloud app settings, never commit. The .example template is fine to track.
.streamlit/secrets.toml

# Re-include seed data (global gitignore excludes *.csv)
!data/owners.csv

# Re-include the expert pick'em sheets — they're the record, not scratch data.
!predictions/picks/*.csv

# Re-include the cloud dashboard artifacts (exported results the deployed
# read-only app renders). Small CSVs, meant to be committed + pushed.
!predictions/cloud/*.csv

# OS
.DS_Store

# Editor / vault
.obsidian/
