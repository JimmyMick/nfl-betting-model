# Copy to .env and adjust. Neo4j requires a password of at least 8 characters.
NEO4J_PASSWORD=password

# For running scripts directly on the host (outside docker compose):
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j

# ── LLM "AI expert" pick'em player (dashboard "AI expert" tab) ────────────────
# Provider-pluggable; set the key for whichever you use. Local-only (the cloud
# app never runs this). Default provider is Claude; switch with LLM_PROVIDER.
LLM_PROVIDER=anthropic            # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional overrides:
# LLM_MODEL=claude-sonnet-4-6     # or gpt-4o; defaults per provider
# AI_PLAYER_NAME=Claude           # how the AI shows on the leaderboard
